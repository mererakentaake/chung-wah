{
  "name": "chung-wah-eschool",
  "version": "1.0.0",
  "description": "Chung Wah E-School Management Platform",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron electron/main.js",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron electron/main.js\"",
    "electron:build": "vite build && electron-builder",
    "cap:android": "npx cap sync android && npx cap open android",
    "cap:sync": "npx cap sync"
  },
  "dependencies": {
    "firebase": "^10.7.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1",
    "framer-motion": "^11.0.3",
    "lucide-react": "^0.303.0",
    "date-fns": "^3.1.0",
    "react-hot-toast": "^2.4.1",
    "clsx": "^2.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.1.3",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0",
    "@capacitor/android": "^5.6.0",
    "@capacitor/cli": "^5.6.0",
    "@capacitor/core": "^5.6.0"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.chungwah.eschool",
    "productName": "Chung Wah E-School",
    "directories": {
      "output": "dist-electron"
    },
    "files": ["dist/**/*", "electron/**/*"],
    "linux": { "target": "AppImage" },
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" }
  }
}
